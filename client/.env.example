# Frontend env template
# Copy this file to .env and fill with your real/public values.

# API Base URL (use production URL on Render)
VITE_API_BASE_URL=http://localhost:3000/api

# Socket.io URL (use production URL on Render)
VITE_SOCKET_URL=http://localhost:4000

# Razorpay public key (client-safe key only)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Cloudinary public config
VITE_CLOUDINARY_CLOUD_NAME=dci28nvyx
VITE_CLOUDINARY_UPLOAD_PRESET=estate
