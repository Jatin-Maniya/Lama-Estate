# Backend env template
# Copy this file to .env and fill with your real values.

PORT=3000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>/<db_name>?retryWrites=true&w=majority
JWT_SECRET_KEY=replace_with_a_strong_secret

# Razorpay (server-side secret keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
